{
  "name": "NewsItem",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "featured_image": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Village Development",
        "School Empowerment",
        "Tree Plantation",
        "Water Conservation",
        "Healthcare",
        "Volunteer Stories",
        "Events",
        "General"
      ]
    },
    "is_published": {
      "type": "boolean",
      "default": true
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "published_at": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "title"
  ]
}