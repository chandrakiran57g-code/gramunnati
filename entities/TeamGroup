{
  "name": "TeamGroup",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Team group name (e.g. Core Team, Advisory Board)"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly slug"
    },
    "description": {
      "type": "string",
      "description": "Short description of this team group"
    },
    "display_order": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "slug"
  ]
}