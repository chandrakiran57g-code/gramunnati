# Production template for cmsr.in — copy to .env on cPanel (/home/cmsr/cmsr/.env)
# Do not commit real passwords to Git.

APP_NAME=GramUnnati
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cmsr.in

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cmsr_db
DB_USERNAME=cmsr_db
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.cmsr.in

SANCTUM_STATEFUL_DOMAINS=cmsr.in,www.cmsr.in

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mail.cmsr.in
MAIL_PORT=465
MAIL_USERNAME=noreply@cmsr.in
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@cmsr.in
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
