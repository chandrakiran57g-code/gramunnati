# =============================================================================
# CMSR — Environment template
# Copy to .env and fill in values. See docs/DEPLOYMENT_STATUS.md for cPanel.
# =============================================================================

APP_NAME=CMSR
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# --- Local dev (SQLite) ---
DB_CONNECTION=sqlite

# --- Production cPanel cmsr.in — see env.cmsr.in.example ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://cmsr.in
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=cmsr_db
# DB_USERNAME=cmsr_db
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

# Local:
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Production:
# SESSION_DOMAIN=.cmsr.in
# SANCTUM_STATEFUL_DOMAINS=cmsr.in,www.cmsr.in

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Mail (cPanel SMTP) — required for password reset + contact replies ---
# MAIL_MAILER=smtp
# MAIL_HOST=mail.cmsr.in
# MAIL_PORT=465
# MAIL_USERNAME=noreply@cmsr.in
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=noreply@cmsr.in
# MAIL_FROM_NAME="${APP_NAME}"

# --- Razorpay payment gateway ---
# Preferred: set rzp_key / rzp_secret in the admin Settings screen instead.
# These env values are a fallback used only if the settings are empty.
# RAZORPAY_KEY=
# RAZORPAY_SECRET=

# Logging: keep at "warning" or "error" in production to avoid noisy logs.
LOG_LEVEL=debug

# Supabase no longer required at runtime
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Never enable on production — shows fake stats/projects when DB is empty
VITE_USE_DEMO_DATA=false

# =============================================================================
# PRODUCTION CHECKLIST (cmsr.in)
#   APP_ENV=production   APP_DEBUG=false   LOG_LEVEL=error
#   Set a strong, unique admin password (php artisan cmsr:reset-admin).
#   Configure MAIL_* for password reset + contact replies.
#   Add rzp_key / rzp_secret in admin Settings to enable live donations.
# =============================================================================
