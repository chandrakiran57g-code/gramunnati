# =============================================================================
# CMSR — Environment template
# Copy to .env and fill in values. See docs/DEPLOYMENT_STATUS.md for cPanel.
# =============================================================================

APP_NAME=CMSR
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# --- Local dev (SQLite) ---
DB_CONNECTION=sqlite

# --- Production cPanel cmsr.in — see env.cmsr.in.example ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://cmsr.in
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=cmsr_db
# DB_USERNAME=cmsr_db
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

# Local:
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Production:
# SESSION_DOMAIN=.cmsr.in
# SANCTUM_STATEFUL_DOMAINS=cmsr.in,www.cmsr.in

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Mail (cPanel SMTP) — optional until forgot-password is wired ---
# MAIL_MAILER=smtp
# MAIL_HOST=mail.cmsr.in
# MAIL_PORT=465
# MAIL_USERNAME=noreply@cmsr.in
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=noreply@cmsr.in
# MAIL_FROM_NAME="${APP_NAME}"

# Supabase no longer required at runtime
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
